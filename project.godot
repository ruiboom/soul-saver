; Engine configuration file — Soul Saver
config_version=5

[application]

config/name="Soul Saver"
config/description="A priest descends into Hell to rescue an innocent soul."
run/main_scene="res://src/ui/title.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.05, 0.04, 0.07, 1)
config/icon="res://assets/icons/pick_wrath.svg"

[autoload]

Rngs="*res://src/autoload/rngs.gd"
MetaSave="*res://src/autoload/meta_save.gd"
AudioDirector="*res://src/autoload/audio_director.gd"
RunState="*res://src/autoload/run_state.gd"
Game="*res://src/autoload/game.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1600
window/size/window_height_override=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

